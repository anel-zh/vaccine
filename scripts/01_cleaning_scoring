# 4. Final assembly 

## 4.1 Combining all data 
Merging all extracted data from sections 2 and 3.
```{r}
combined_data <- 
  # Adding static data
  demographics %>%
  left_join(processed_zip, by = "record_id") %>%
  left_join(processed_physio_neuro, by = "record_id") %>%
  
  # Adding longitudinal data
  left_join(time_stamps, by = "record_id") %>%
  left_join(vaccination_data, by = "record_id") %>%
  left_join(scored_fear_of_infection, by = "record_id") %>%
  left_join(scored_family_diagnosis, by = "record_id") %>%
  left_join(scored_covid_combined, by = "record_id") %>%
  left_join(scored_psi, by = "record_id") %>%
  left_join(scored_stress_stay_home, by = "record_id") %>%
  left_join(other_scales_data, by = "record_id")
```

## 4.2 Cleaning up
Changing "prefer not to say" to NA, filtering age and removing "total" scores of psychological scales 
- drop_na is not included at this step
```{r}
master_database <- combined_data %>% 
  # Removing total scores of pscyhological scales 
  dplyr::select(-matches('total')) %>% 
  # Changing "Prefer not to say" options to NA
  mutate(psych_history = na_if(psych_history, 2)) %>%
  mutate(sex = na_if(sex, 2)) %>% # removing followingly "other" gender option

  mutate(across(starts_with("take_vaccination"),~ na_if(., 2))) %>%

  # Logic: < 5 is Insured (1), >= 5 is Uninsured (0); 6,7 -> NA 
  mutate(health_insurance = na_if(health_insurance, 6)) %>%
  mutate(health_insurance = na_if(health_insurance, 7)) %>%
  mutate(health_insurance = ifelse(health_insurance < 5, 1, 0)) %>% # order is important 
  
  # Age filter: keeping only age range of 10-100
  filter(age >= 10 & age <= 100) 

head(master_database)
```

QC final variables 
```{r}
pattern <- paste0("(", paste0('_', timepoints, collapse = "|"), ")$")

variable_summary <- tibble(
  full_name = colnames(master_database),
  type = sapply(master_database, function(x) class(x)[1])  # can change to loaded_data to check for all
) %>%
  mutate(
    base_name = str_remove(full_name, pattern),
    found_suffix = str_extract(full_name, pattern)
  ) %>%
  group_by(base_name) %>%
  summarise(
    data_type = first(type),
    num_timepoints = n(),
    list_of_timepoints = paste(sort(na.omit(found_suffix)), collapse = ", "),
    
    range = {
      all_vals <- unlist(master_database[, full_name])
      clean_vals <- all_vals[!is.na(all_vals)]
      
      if (length(clean_vals) == 0) {
        "All NA"
      } else if (first(type) == "Date") {
        # Convert the unlisted integers back to Dates
        date_vals <- as.Date(clean_vals, origin = "1970-01-01")
        paste0(min(date_vals), " to ", max(date_vals))
      } else if (first(type) %in% c("numeric", "integer")) {
        paste0(min(clean_vals), " - ", max(clean_vals))
      } else {
        paste0(length(unique(clean_vals)), " unique labels")
      }
    }
  ) %>%
  mutate(list_of_timepoints = if_else(list_of_timepoints %in% c("", "_month0"), "Single observation", list_of_timepoints)) %>%
  arrange(list_of_timepoints)

print(variable_summary, n = Inf)
```

  
  
Saving the master database  
```{r}
write.csv(variable_summary, "../data/processed/QC_variables_of_master_database.csv", row.names = FALSE) # 60 unique vars + record_id
write.csv(master_database, "../data/processed/master_database.csv", row.names = FALSE) # 2177 obs 319 var
```

