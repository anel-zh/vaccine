# 1. Setup and preparation

Loading project utilities and the cohort dataset.
```{r setup, message=FALSE, warning=FALSE}
# setwd("../scripts")

source("../R/load_packages.R")
source("../R/config.R")

# Loading the main dataset and the zip code helper.
loaded_data_raw <- read.csv("../data/raw/COVERT_cumulative_data_Final_14Jan25.csv") # 2177 obs. of 2936 variables
zip_data    <- read.csv("../data/raw/zip_match.csv") # 2224 obs. of 3 variables
```

Renaming the timepoint suffix and prefixes for convenience 
```{r}
# Defining suffix mapping (old -> new)
suffix_map <- list(
  "_baseline"       = "_month0",
  "_two_week"       = "_2week",
  "_second_monthly" = "_month2",  
  "_third_monthly"  = "_month3",  
  "_monthly"        = "_month1", 
  "_six_week"       = "_6week",
  "_ten_week"       = "_10week"
)

# Renaming suffixes
loaded_data <- loaded_data_raw
for (old_suffix in names(suffix_map)) {
  new_suffix <- suffix_map[[old_suffix]]
  loaded_data <- loaded_data %>%
    rename_with(
      .fn = ~ sub(paste0(old_suffix, "$"), new_suffix, .), 
      .cols = ends_with(old_suffix)
    )
}

# Renaming prefixes
# This handles the 'take_vaccination' and 'date_complete' variables
loaded_data <- loaded_data %>%
  rename_with(~ paste0(sub("^m_", "", .), "_month1"), starts_with("m_")) %>%
  rename_with(~ paste0(sub("^sec_m_", "", .), "_month2"), starts_with("sec_m_")) %>%
  rename_with(~ paste0(sub("^third_m_", "", .), "_month3"), starts_with("third_m_")) %>%
  rename_with(~ paste0(sub("^t_", "", .), "_2week"), starts_with("t_")) %>%
  rename_with(~ paste0(sub("^two_week_", "", .), "_2week"), starts_with("two_week")) %>%
  rename_with(~ paste0(sub("^six_week_", "", .), "_6week"), starts_with("six_week")) %>%
  rename_with(~ paste0(sub("^six_", "", .), "_6week"), starts_with("six_")) %>%
  rename_with(~ paste0(sub("^ten_", "", .), "_10week"), starts_with("ten_"))  %>%

  # This handles the ".x" and baseline inconsistencies
  rename_with(~ gsub("baseline_date_complete.x", "date_complete_month0", .)) %>%
  rename_with(~ gsub("date_complete.x", "date_complete", .))  %>% # Removes .x from all others
  rename(take_vaccination_month0 = take_vaccination)

```

# 2. Static data processing
This section processes variables that do not change over time and were collected at baseline.

## 2.1 Demographics

Extracting demographic information (e.g., age, education, sex)
```{r}
# Demographics data collected ones
demographics <- loaded_data %>%
  select(record_id, 
         sex, 
         age = age_month0,
         education, 
         area_type, 
         psych_history, 
         essential_worker_at_home, 
         health_insurance) 
```

Collapsing low N categories for education: <HS, Some HS, and HS/GED into one category (0) and re-indexing the rest so the scale is continuous (0-4)
```{r}
demographics <- demographics %>%
  mutate(education = case_when(
    education <= 2 ~ 0, # 0, 1, and 2 into "HS or Less"
    education == 3 ~ 1, # College (2yr)
    education == 4 ~ 2, # College (4yr)
    education == 5 ~ 3, # Post-College
    education == 6 ~ 4, # > Graduate
    TRUE ~ NA_real_     # Missing
  ))

# table(demographics$education)
```

## 2.2 State colors (Red vs Blue)

Mapping zip codes to state political colors (1=Blue, 2=Red).
```{r}
# Defining state lists
states1 <- c("Maine","Vermont","New Hampshire","Massachusetts","Connecticut","Rhode Island",
             "Delaware",  "Washington, D.C.", "New York", "New Jersey", "Pennsylvania", "Maryland", 
             "Virginia","Georgia","Michigan", "Illinois", "Wisconsin", "Minnesota", "Colorado", 
             "New Mexico", "Arizona", "Nevada", "California", "Hawaii", "Oregon", "Washington")

states2  <- c("Ohio","West Virginia","North Carolina", "South Carolina", "Florida", "Alabama",
              "Mississippi","Louisiana","Indiana", "Kentucky", "Tennessee", "Arkansas","Missouri",
              "Iowa","North Dakota", "South Dakota","Nebraska","Kansas","Oklahoma", "Texas", "Wyoming",
              "Utah","Idaho","Montana", "Alaska")

# Processing zip data
processed_zip <- zip_data %>%
  mutate(state = na_if(state, "#FIELD!")) %>%
  mutate(state_color = case_when(
    state %in% states1 ~ 1, # Blue
    state %in% states2 ~ 2,  # Red
    TRUE ~ NA_real_             # Other/Missing
  )) %>%
  select(record_id, state_color)
```

## 2.2 Physio and neuro scores

Summing checklists for physical and neurological conditions.
```{r}
processed_physio_neuro <- loaded_data %>%
  # Physio score: sum of allergies, asthma, diabetes, etc. (excluding epilepsy)
  mutate(physio = rowSums(select(., has_seasonal_allergies:has_skin_problems) %>% 
                                  select(-matches("epilepsy")), na.rm = TRUE)) %>%
  
  # Neuro score: sum of mental health, learning disorders, epilepsy
  mutate(neurological = rowSums(select(., has_emotional_mental_health_problems:has_learning_disorder, 
                                      has_epilepsy_seizures), na.rm = TRUE)) %>% 
  # Apply caps: Physio max 4, Neuro max 2
  mutate(
    physio = pmin(physio, 4),
    neurological = pmin(neurological, 2)
  ) %>%
  
  select(record_id, physio, neurological)
```


# 3. Longitudinal scoring
This section handles the "complex scores"—variables that need math (summing or recoding) before we can use them. We calculate scores for all timepoints simultaneously. 
```{r}
timepoints  <- c("month0","2week", "month1", "6week","month2","10week","month3") 
```

## 3.1 Time-stamps
Considering that the data was collected in different time periods, time stamps for completion of each surveys are extracted for future analysis. 
```{r}
time_stamps <- loaded_data %>% 
  select(record_id, matches("complete"), -matches("complete.y")) %>%
  # converting date format to YYYY-MM-DD format
  mutate(across(starts_with("date_"), ~ as_date(mdy_hm(., quiet = TRUE)))) 
```

## 3.2 Vaccination intent 

Extracting the outcome variable
-   The question that was asked:"Would you get vaccinated for COVID-19
    if an approved vaccine was given to you today?"
-   Possible responses: "0, Yes \| 1, No \| 2, Prefer not to answer"
In later steps, prefer not to answer option will be removed. Additionally time-stamps for each period were collected 

```{r}
vaccination_data <- loaded_data %>% select(record_id, matches("take_vaccination")) 
```

## 3.3 Fear of infection

The score is calculated based on the summation of "Fear of Self Infection" and "Fear of Family Infection".
```{r}
scored_fear_of_infection <- loaded_data %>% select(record_id)

for (tp in timepoints) {
  col_self   <- paste0("fear_self_infected_", tp)
  col_family <- paste0("fear_family_infected_", tp)
  
  # Calculate
  if (col_self %in% names(loaded_data) & col_family %in% names(loaded_data)) {
    scored_fear_of_infection[[paste0("fear_of_infection_", tp)]] <- rowSums(
    loaded_data[c(col_self, col_family)], 
    na.rm = TRUE # still summing if one is NA
)
  }
}

```

## 3.4 COVID diagnosis: family

Re-coding to 0/1 scale

Original: 
0 = Yes Non-Household 
1 = Yes Household 
2 =  No Diagnosis 

Re-coded:
0 = Yes Non-Household and/or Yes Household 
1 = No 
```{r}
# Helper function for recoding
recode_fam <- function(h, nh, n) {

case_when(
  h == 1 | nh == 1 ~ 0, # Any diagnosis yes
  n == 1  ~ 1, # None
  TRUE ~ NA_real_  # Missing
)
}
scored_family_diagnosis <- loaded_data %>% select(record_id)

for (tp in timepoints) {
  
  # Construct the specific column names
  col_h  <- paste0("covid_family_diag_household_", tp)
  col_nh <- paste0("covid_family_diag_non_household_", tp)
  col_n  <- paste0("covid_family_diag_none_", tp)
  
  # Calculate
  if (col_h %in% names(loaded_data)) {
    scored_family_diagnosis[[paste0("covid_diagnosed_family_", tp)]] <-  recode_fam(
      loaded_data[[col_h]], 
      loaded_data[[col_nh]], 
      loaded_data[[col_n]]
    )
  }
}
```

## 3.5 COVID suspected: self

Combining covid_suspected and combining with covid_diagnosed

Covid_suspected (self):
  Original:
  0 = Yes, with a positive test
  1 = Yes, medical diagnosis, but no test
  2 = Yes, have had some symptoms but no diagnosis by doctor
  3 = No symptoms or signs

  Re-coded:
  0 = Yes (with a positive test/ medical diagnosis, but no test/ have had some symptoms but no diagnosis by doctor)
  1 = No
  
Covid_diagnosed (self):
  Original:
  0 = Yes
  1 = No
  2 = I'm not sure
  
  Re-coded:
  0 = Yes
  1 = No
  2 = NA
  
Final re-coded: 
0 = Yes (Suspected or Diagnosed), 1 = No, NA = Not sure/Missing
```{r}
# Helper Function
recode_covid <- function(suspected, diagnosed) {
  # Suspected: 0,1,2 -> 0 (Yes); 3 -> 1 (No)
  s_bin <- case_when(
    suspected %in% c(0,1,2) ~ 0,
    suspected == 3          ~ 1,
    TRUE                    ~ NA_real_
  )
  
  # Diagnosed: 0 -> 0 (Yes); 1 -> 1 (No); 2 -> NA
  d_bin <- case_when(
    diagnosed == 0 ~ 0,
    diagnosed == 1 ~ 1,
    TRUE           ~ NA_real_ # Handles 2 and NA
  )
  
  # Combine: 0 (Yes) takes precedence over 1 (No)
  pmin(s_bin, d_bin, na.rm = TRUE)
}

scored_covid_combined <- loaded_data %>% select(record_id)

for (tp in timepoints) {
  s_col <- paste0("covid_suspected_", tp)
  d_col <- paste0("covid_diagnosed_", tp)
  
  if (s_col %in% names(loaded_data) & d_col %in% names(loaded_data)) {
    scored_covid_combined[[paste0("covid_diagnosed_self_", tp)]] <- 
      recode_covid(loaded_data[[s_col]], loaded_data[[d_col]])
  }
}
```

## 3.5 Pandemic stress index

Checking all that applied
```{r}
# Classifying pandemic stress index response into positive and negative 
psi_pos_items <- c(
  "greater_good", "emo_support_others", "finan_support_others"
)

psi_neg_items <- c(
  "covid_diag", "covid_fear_ofgetting", "covid_fear_ofgiving", "worry", "stigma", 
  "finan_loss", "boredom", "lack_supplies", "anxiety", "depression", 
  "sleep_changes", "substance", "sexual_changes", "loneliness", "confusion",
  "other_diff"
)


# Helper function to sum items
calculate_psi_sum <- function(data_row) {
  if (all(is.na(data_row))) return(NA_real_) #  check if all items are NA so we don't return 0 for a missing survey.
  sum(data_row, na.rm = TRUE)
}

scored_psi <- loaded_data %>% select(record_id)

for (tp in timepoints) {
  
  cols_neg <- paste0("pandemic_stress_", psi_neg_items, "_", tp)
  cols_pos <- paste0("pandemic_stress_", psi_pos_items, "_", tp)
  
  if (all(cols_neg %in% names(loaded_data))) {
    
    # Calculate negative score
    scored_psi[[paste0("pandemic_stress_index_negative_", tp)]] <- apply(
      loaded_data[, cols_neg], 1, calculate_psi_sum
    )
    
    # Calculate positive score
    scored_psi[[paste0("pandemic_stress_index_positive_", tp)]] <- apply(
      loaded_data[, cols_pos], 1, calculate_psi_sum
    )
    
  }
}
```

## 3.7 Stress staying home 

Collapse "Extremely" and "Very" into one due to small N within categories. 
Logic: 0->0, 1->1, 2->2, 3&4->3
```{r}
# Helper function for collapsing
recode_stay_home <- function(x) {
  case_when(
    x %in% c(3, 4) ~ 3, # Collapse 3 and 4 into 3 
    x %in% 0:2 ~ x,     # Keep 0, 1, and 2 as they are
    TRUE  ~ NA_real_    # Missing 
  )
}
scored_stress_stay_home <- loaded_data %>% select(record_id)

for (tp in timepoints) {
  old_col <- paste0("covid_stress_restrict_out_", tp)
  new_col <- paste0("stress_stay_home_", tp)
  
  if (old_col %in% names(loaded_data)) {
    scored_stress_stay_home[[new_col]] <- recode_stay_home(loaded_data[[old_col]])
  }
}

# 4. Check the results for month0 to verify counts
table(scored_stress_stay_home$stress_stay_home_month0, useNA = "always")

```


